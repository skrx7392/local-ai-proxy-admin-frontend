# Frontend env vars — copy to .env.local and fill in.
# See PLAN.md "Environment Variables" for full documentation.

# Cluster-internal backend URL (used by BFF proxy only)
BACKEND_URL=http://ai-proxy.local-ai.svc.cluster.local:80

# 32+ char random string used by next-auth v5 to encrypt the JWT.
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-32-plus-char-random-string

# Canonical public URL — required in prod, optional in dev
AUTH_URL=https://admin.ai.kinvee.in

# Required in k8s behind Traefik/ingress
AUTH_TRUST_HOST=true

NODE_ENV=development
PORT=3000

NEXT_PUBLIC_APP_NAME=local-ai admin
NEXT_TELEMETRY_DISABLED=1
LOG_LEVEL=info
